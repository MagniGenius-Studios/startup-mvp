{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src",

    "esModuleInterop": true,
    "moduleResolution": "node16",

    "strict": false,                // 🔥 relax strict mode
    "skipLibCheck": true,           // 🔥 ignore lib errors

    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}