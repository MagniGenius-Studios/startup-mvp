{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src",

    "esModuleInterop": true,
    "moduleResolution": "node",

    "strict": false,                // 🔥 relax strict mode
    "skipLibCheck": true,           // 🔥 ignore lib errors

    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  }
}