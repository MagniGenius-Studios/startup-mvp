generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// TODO: Extend with organizations, tracks, modules, and lessons models in the next milestone.

enum SubmissionStatus {
  PENDING
  REVIEWED
  ACCEPTED

  @@map("submission_status")
}

model User {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String           @unique
  name           String?
  createdAt      DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt      DateTime         @updatedAt @db.Timestamptz(6) @map("updated_at")
  submissions    Submission[]
  conceptMastery ConceptMastery[]
  reflections    Reflection[]
  events         Event[]

  @@map("users")
}

model Problem {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String       @unique
  title       String
  description String?
  difficulty  String?      @default("beginner")
  createdAt   DateTime     @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime     @updatedAt @db.Timestamptz(6) @map("updated_at")
  submissions Submission[]

  @@map("problems")
}

model Submission {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String           @map("user_id") @db.Uuid
  problemId  String           @map("problem_id") @db.Uuid
  code       String
  language   String           @default("javascript")
  status     SubmissionStatus @default(PENDING)
  score      Float?
  createdAt  DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt  DateTime         @updatedAt @db.Timestamptz(6) @map("updated_at")
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem    Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
  aiFeedback AiFeedback[]
  reflections Reflection[]

  @@index([userId])
  @@index([problemId])
  @@map("submissions")
}

model AiFeedback {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submissionId String      @map("submission_id") @db.Uuid
  feedbackText String      @map("feedback_text")
  model        String?
  createdAt    DateTime    @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt    DateTime    @updatedAt @db.Timestamptz(6) @map("updated_at")
  submission   Submission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("ai_feedback")
}

model ConceptMastery {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  concept        String
  masteryScore   Float     @default(0) @map("mastery_score")
  lastAssessedAt DateTime? @db.Timestamptz(6) @map("last_assessed_at")
  createdAt      DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6) @map("updated_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, concept])
  @@index([userId])
  @@map("concept_mastery")
}

model Reflection {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String      @map("user_id") @db.Uuid
  submissionId String?     @map("submission_id") @db.Uuid
  content      String
  createdAt    DateTime    @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt    DateTime    @updatedAt @db.Timestamptz(6) @map("updated_at")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([submissionId])
  @@map("reflections")
}

model Event {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  eventType String    @map("event_type")
  payload   Json?
  createdAt DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt DateTime  @updatedAt @db.Timestamptz(6) @map("updated_at")
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@map("events")
}
